# Copy to .env and fill in. Never commit your real .env.

# Required — password for the dashboard login (any string you choose).
DASHBOARD_PASSWORD=change-me

# Optional — port to bind (default 8001).
# PORT=8001

# --- Usage pill (optional) ---
# The /api/usage endpoint reads your OWN local CLI OAuth credentials to show
# remaining quota. No secrets are stored by this app; it only reads these files
# at runtime if they exist:
#   ~/.claude/.credentials.json   (Claude Code)
#   ~/.codex/auth.json            (Codex)
# If absent, the usage pill simply shows nothing — the app still runs.
